{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    },
    "nuget": {
      "type": "local",
      "command": ["dnx", "NuGet.Mcp.Server@1.2.3", "--yes", "--source", "https://api.nuget.org/v3/index.json"]
    },
    "awesome-copilot": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "ghcr.io/microsoft/mcp-dotnet-samples/awesome-copilot:1.0.2026040100"]
    },
    "microsoftdocs": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "aspire": {
      "type": "local",
      "command": ["aspire", "mcp", "start"]
    }
  }
}